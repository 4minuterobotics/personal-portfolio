# Copy this file to `.env.local` and fill in the values from your EmailJS dashboard.
# `.env.local` is gitignored — these are public-safe but should still not live in source.
#
# Get values from:
#   - Service ID:  https://dashboard.emailjs.com/admin → Email Services → your service
#   - Template ID: https://dashboard.emailjs.com/admin → Email Templates → your template
#   - Public Key:  https://dashboard.emailjs.com/admin/account/general

VITE_APP_EMAILJS_SERVICE_ID=
VITE_APP_EMAILJS_TEMPLATE_ID=
VITE_APP_EMAILJS_PUBLIC_KEY=
